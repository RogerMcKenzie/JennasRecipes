# Google AI Studio key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional override if your key only has access to specific Gemini models.
# Example values: gemini-2.5-flash, gemini-1.5-flash-latest
VITE_GEMINI_MODEL=gemini-2.5-flash

# Spoonacular key: https://spoonacular.com/food-api
VITE_SPOONACULAR_KEY=your_spoonacular_api_key_here
